{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "strict": true,
    "outDir": "dist/",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": ["src/**/*", "lib/**/*"],
  "exclude": ["scripts/**", "node_modules"]
}
