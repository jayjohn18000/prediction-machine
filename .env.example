# Supabase (required for observer)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY=""

# Optional: direct Postgres for API (avoids PostgREST schema cache issues for /signals/top and /execution-decision)
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"

# Optional
# SPREAD_EVENT_PAIRS_PATH="./event_pairs.json"
# SPREAD_OBSERVER_INTERVAL_SEC=60

# API auth and SLO thresholds
# PMCI_API_KEY=""              # If set, gates all non-health, non-review GET routes (x-pmci-api-key header)
# PMCI_ADMIN_KEY=""            # Gates POST /v1/resolve/link only
# PMCI_MAX_LAG_SECONDS=120     # API default 120s; bootstrap CLI default 120s
# PMCI_INGESTION_SUCCESS_TARGET=0.99
# PMCI_API_P95_TARGET_MS=500

# Rate limiting (per key, non-health routes)
# PMCI_RATE_LIMIT_MAX=60         # requests per window per key
# PMCI_RATE_LIMIT_WINDOW_MS=60000

# Reverse proxy / deployment
# PMCI_HOST="api.yourdomain.com"  # Used by Caddyfile
# CADDY_ACME_EMAIL=""             # For Let's Encrypt cert provisioning

# PMCI politics universe ingestion (Phase 1; optional)
# - Kalshi: list events by series ticker(s), then ingest markets per event (throttled; 429 retry + optional checkpoint)
# - Polymarket: list events by tag_id, then ingest markets within each event
# PMCI_POLITICS_KALSHI_SERIES_TICKERS="SERIES_TICKER_1,SERIES_TICKER_2"
# PMCI_POLITICS_POLY_TAG_ID="12345"
# PMCI_POLITICS_MAX_EVENTS_PER_PROVIDER=50
# PMCI_POLITICS_REQUEST_DELAY_MS=250
# PMCI_POLITICS_KALSHI_CONCURRENCY=1
# PMCI_POLITICS_KALSHI_MAX_EVENTS=50
# PMCI_POLITICS_KALSHI_MAX_RETRIES=6
# PMCI_POLITICS_POLY_CONCURRENCY=5
# Resume: script writes .pmci_kalshi_universe_checkpoint.json; run with --reset to start fresh.
