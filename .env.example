# Supabase (required for observer)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY=""

# Optional: direct Postgres for API (avoids PostgREST schema cache issues for /signals/top and /execution-decision)
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"

# Optional
# SPREAD_EVENT_PAIRS_PATH="./event_pairs.json"
# SPREAD_OBSERVER_INTERVAL_SEC=60
